{
  "name": "lager",
  "version": "1.0.0",
  "description": "Lagerhantering for karossdelar",
  "main": "electron-main.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server.cjs",
    "electron": "electron electron-main.js",
    "dist": "npm run build && electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "se.lager.app",
    "productName": "Lager",
    "publish": {
      "provider": "github",
      "owner": "Chrish6",
      "repo": "lager"
    },
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lager",
      "runAfterFinish": true,
      "language": "1053"
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "sqlite3": "^5.1.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0",
    "electron-updater": "^6.3.0",
    "vite": "^5.0.0"
  }
}
