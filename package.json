{
  "name": "lager",
  "version": "1.0.0",
  "description": "Lagerhantering f\u00f6r karossdelar",
  "main": "electron-main.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server.cjs",
    "electron": "electron electron-main.js",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "se.lager.app",
    "productName": "Lager",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "server.cjs",
      "electron-main.js",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lager",
      "runAfterFinish": true,
      "language": "1053"
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.0.0"
  }
}